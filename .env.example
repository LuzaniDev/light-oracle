# Oracle RAG - Configuracoes
# Copie este arquivo como .env e ajuste conforme necessario
# Valores marcados com # (default) sao os padroes usados se nao definidos

# === DIRETORIOS ===
# Diretorio base para dados de runtime (indices, uploads, cache)
# (default: %TEMP%/oracle-rag no Windows, /tmp/oracle-rag no Linux)
# ORACLE_BASE_DIR=

# === MODELOS DE EMBEDDING ===
# Modelo para gerar embeddings dos textos
# (default: BAAI/bge-small-en-v1.5)
# ORACLE_EMBED_MODEL=

# Dimensao final dos embeddings (cortado do modelo original)
# (default: 256)
# ORACLE_EMBED_DIM=

# Batch size para processamento de embeddings
# (default: 32)
# ORACLE_EMBED_BATCH=

# === RERANKER ===
# Modelo cross-encoder para re-pontuacao dos resultados
# (default: cross-encoder/ms-marco-MiniLM-L-2-v2)
# ORACLE_RERANKER_MODEL=

# === CHUNKING ===
# Tamanho maximo de cada chunk em numero de palavras
# (default: 512)
# ORACLE_CHUNK_SIZE=

# Sobreposicao entre chunks em palavras
# (default: 64)
# ORACLE_CHUNK_OVERLAP=

# === RETRIEVAL ===
# Quantidade de resultados do BM25
# (default: 50)
# ORACLE_BM25_TOP_K=

# Quantidade de resultados da busca densa
# (default: 50)
# ORACLE_DENSE_TOP_K=

# Quantidade de resultados apos fusao RRF
# (default: 30)
# ORACLE_RRF_TOP_K=

# === SELF-RAG ===
# Confianca minima para resposta ser considerada "Suportada"
# (default: 0.60)
# ORACLE_CONFIDENCE_HIGH=

# Confianca minima para resposta ser considerada "Parcial"
# (default: 0.40)
# ORACLE_CONFIDENCE_MEDIUM=

# === WEB FALLBACK ===
# Ativar busca na web quando documento nao tem resposta
# (default: true)
# ORACLE_WEB_FALLBACK=

# Maximo de resultados da busca web
# (default: 5)
# ORACLE_WEB_MAX_RESULTS=

# === SERVIDOR WEB ===
# Porta do servidor web
# (default: 8081)
# ORACLE_WEB_PORT=

# Host do servidor web
# (default: 127.0.0.1)
# ORACLE_WEB_HOST=

# === FIREBIRD (LK.ECO) ===
# Host do servidor Firebird
# (default: localhost)
# ORACLE_FB_HOST=

# Usuario do Firebird
# (default: SYSDBA)
# ORACLE_FB_USER=

# Senha do Firebird
# (default: masterkey)
# ORACLE_FB_PASSWORD=
